<%- include("layouts/header") %>

  <body>
    <%- include("layouts/nav1") %>
      <div class="hero page-inner overlay" style="background-image: url('images/hero_bg_1.jpg')">
        <div class="container">
          <div class="row justify-content-center align-items-center">
            <div class="col-lg-9 text-center mt-5">
              <h1 class="heading" data-aos="fade-up">Garyrimülkler</h1>

              <nav aria-label="breadcrumb" data-aos="fade-up" data-aos-delay="200">
                <ol class="breadcrumb text-center justify-content-center">
                  <li class="breadcrumb-item"><a href="/">Ana Sayfa</a></li>
                  <li class="breadcrumb-item active text-white-50" aria-current="page">
                    Garyrimülkler
                  </li>
                </ol>
              </nav>
            </div>
          </div>
        </div>
      </div>

      <div class="section">
        <div class="container">
          <div class="row mb-5 align-items-center">
            <div class="col-lg-6 text-center mx-auto">
              <h2 class="font-weight-bold text-primary heading">
                Öne Çıkan Garyrimülkler
              </h2>
            </div>
          </div>
          <%- include("layouts/popiler-gaymenkul") %>
        </div>
      </div>

      <div class="section section-properties">
        <div class="container">
          <div class="row">
            <nav class="navbar bg-body-tertiary">
              <div class="container-fluid" style="
                border: 2px solid black;
                border-radius: 20px;
                margin-bottom: 10px;
                border-color: #255656;
              ">
                <a class="navbar-brand ">Filtre</a>
                <form class="d-flex" role="search">
                  <div class="row">

                    <div class="col">
                      <select class="form-select" aria-label="Default select example">
                        <option selected>Oda Sayısı</option>
                        <option value="1">3-1</option>
                        <option value="2">2-1</option>
                        <option value="3">1-1</option>
                      </select>
                    </div>
                    <div class="col">
                      <select class="form-select" aria-label="Default select example">
                        <option selected>Banyo Sayısı</option>
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                      </select>
                    </div>

                    <div class="col">
                      <select class="form-select" aria-label="Default select example">
                        <option selected>Metre Kare</option>
                        <option value="1">100m2 küçük</option>
                        <option value="2">100m2 büyük</option>
                      </select>
                    </div>
                    <div class="col">
                      <select class="form-select" aria-label="Default select example">
                        <option selected>Sırala</option>
                        <option value="1">Tarih</option>
                        <option value="2">Fiyat</option>
                      </select>
                    </div>

                  </div>
                </form>
              </div>
            </nav>


            <% if(mulk_data){ %>
              <% mulk_data.forEach(v_m=> { %>
                <div data-mulk-id="<%= v_m._id %>" class="property col-xs-12 col-sm-6 col-md-6 col-lg-4">
                  <div class="property-item mb-30">
                    <h5>Seri nu: <%= v_m.seri_number _%>
                    </h5>
                    <a href="property-single" class="img">
                      <div id="carouselExampleIndicators<%= v_m._id %>" class="carousel slide">

                        <div class="carousel-inner">
                          <div class="carousel-item active">
                            <img data-src="images/mulk-images/5x5/<%= v_m.image[0] %>" class="d-block w-100"
                              alt="ilan resmi">
                          </div>
                            <% for (let index=1; index < v_m.image.length; index++) { %>
                              <div class="carousel-item">
                                <img data-src="images/mulk-images/5x5/<%= v_m.image[index] _%>" class="d-block w-100" alt="ilan resim">
                              </div>
                             <%  } %>
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators<%= v_m._id %>"
                          data-bs-slide="prev">
                          <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                          <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators<%= v_m._id %>"
                          data-bs-slide="next">
                          <span class="carousel-control-next-icon" aria-hidden="true"></span>
                          <span class="visually-hidden">Next</span>
                        </button>
                      </div>
                    </a>

                    <div class="property-content">
                      <div class="price mb-2">$<%= v_m.price %> 
                        <% if(v_m.proje === true){ %>
                        <p style="float: right; color: red;">Projeden</p>
                        <% } %>
                      </div>
                      <div>
                        <span class="d-block mb-2 text-black-50">
                          <%= v_m.adress %>
                        </span>
                        <span class="city d-block mb-3">
                          <%= v_m.country %> / Kıbrıs
                        </span>

                        <div class="specs d-flex mb-4">
                          <span class="d-block d-flex align-items-center me-3">
                            <span class="icon-home me-2"></span>
                            <span class="caption">
                              <%= v_m.room %>
                            </span>
                          </span>
                          <span class="d-block d-flex align-items-center me-3">
                            <span class="icon-bed me-2"></span>
                            <span class="caption">
                              <%= v_m.bedroom %>
                            </span>
                          </span>
                          <span class="d-block d-flex align-items-center me-3">
                            <span class="icon-bath me-2"></span>
                            <span class="caption">
                              <%= v_m.bath %>
                            </span>
                          </span>

                          <span class="d-block d-flex align-items-center ">
                            <span class="icon-area-chart me-2"></span>
                            <span class="caption">
                              <%= v_m.area_net %>m2
                            </span>
                          </span>
                        </div>

                        <div class="d-flex">
                          <a data-mulk-id="<%= v_m._id %>" href="property-single/<%= v_m._id _%>"
                      class="btn btn-primary py-2 px-3 text-uppercase">incele</a>
                          <a target="_blank"
                            href="https://wa.me/905517026813?text=Merhaba,<%= v_m._id _%>,seri numaralı ilan ile ilgili bilgi almak istiyorum."><i
                              class="bi bi-whatsapp"></i></a>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              <% }); %>
            <% } %>


          </div>
          <div class="row align-items-center py-5">
            <div style="position: relative;" class="col-12"><hr></div>
            <div style=" position: absolute; display: flex; justify-content: center;">
              <button class="btn btn-primary" id="yukle" style="border-radius: 20px;" type="button">Daha fazla yükle</button>
            </div>
            
            <!-- <div class="col-lg-3">Sayfa (1 of 10)</div>
            <div class="col-lg-6 text-center">
              <div class="custom-pagination">
                <a href="#">1</a>
                <a href="#" class="active">2</a>
                <a href="#">3</a>
                <a href="#">4</a>
                <a href="#">5</a>
              </div>
            </div> -->
          </div>
        </div>
      </div>
      <%- include("layouts/footer") %>