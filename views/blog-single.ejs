<%- include("layouts/header") %>

  <body>
    <%- include("layouts/nav1") %>
      <div class="hero page-inner overlay" style="background-image: url('images/hero_bg_1.jpg')">
        <div class="container">
          <div class="row justify-content-center align-items-center">
            <div class="col-lg-9 text-center mt-5">
              <h1 class="heading" data-aos="fade-up">Blog</h1>

              <nav aria-label="breadcrumb" data-aos="fade-up" data-aos-delay="200">
                <ol class="breadcrumb text-center justify-content-center">
                  <li class="breadcrumb-item"><a href="/">Ana Sayfa</a></li>
                  <li class="breadcrumb-item"><a href="/blog">Blog Ana Sayfa</a></li>
                  <li class="breadcrumb-item active text-white-50" aria-current="page">
                    <%= blog_single.title %>
                  </li>
                </ol>
              </nav>
            </div>
          </div>
        </div>
      </div>


      <div class="section">
        <div class="container">
          <div class="row justify-content-between">
            <div class="col-lg-2 d-md-block d-sm-none d-none">
              <img class="w-100" src="/images/<%= blog_single.blog_single_image %>.jpg" alt="Image" />
            </div>
            <div class="col-lg-10">
              <h2 style="text-transform: capitalize;" class="heading text-primary">
                <%= blog_single.title _%>
              </h2>
              <p class="meta">
                <%= blog_single.title _%>
              </p>
              <% for (let index=0; index < blog_single.text.length; index++) { %>
                <p style="text-transform: capitalize;" class="text-black-50">
                  <%= blog_single.text[index] _%>
                </p>
                <% } %>
            </div>
          </div>
        </div>
      </div>
      <hr>
      <div class="d-flex justify-content-center">
        <button data-toggle="modal" data-target="#yorumModal" type="button" class="btn btn-warning">Yorumlayın...</button>
      </div>
      <hr>
      <div class="container commit">
        <h2>YORUMLAR</h2>
        <div class="item">
          <div class="testimonial">
            <h3 class="h5 text-primary mb-4">James Smith</h3>
            <blockquote>
              <p>
                &ldquo;Far far away, behind the word mountains, far from the
                countries Vokalia and Consonantia, there live the blind
                texts. Separated they live in Bookmarksgrove right at the
                coast of the Semantics, a large language ocean.&rdquo;
              </p>
            </blockquote>
          </div>
          <p style="margin-left: 20px;">Cevap: Lorem ipsum dolor sit amet consectetur adipisicing elit. Aut incidunt
            magni numquam quasi dolores,
            autem fugit facere. Nulla necessitatibus ipsum non id fuga, enim dolores, iusto delectus, qui rem repellat.
          </p>
        </div>
        <div class="btn-group" role="group" aria-label="Basic example">
          <button type="button" class="btn btn-danger">sil</button>
          <button type="button" class="btn btn-info">cevapla</button>
        </div>
      </div>
      <hr>


      <!--Yorum Modal -->
      <div class="modal fade" id="yorumModal" tabindex="-1" role="dialog" aria-labelledby="yorumModalLabel"
        aria-hidden="true">
        <div class="modal-dialog" role="document">
          <div class="modal-content">
            <div class="modal-header">
            </div>
            <div class="modal-body">
              <textarea style="width: 100%; resize: none;" name="yorum" rows="4" cols=""></textarea>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-dismiss="modal">Kapat</button>
              <button type="button" class="btn btn-primary">Kaydet</button>
            </div>
          </div>
        </div>
      </div>
      <!--yorum Modal -->


      <%- include("layouts/footer") %>